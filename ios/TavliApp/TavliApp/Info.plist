    <string>Synchronisiert das Turnier mit anderen iPads im selben WLAN.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_tavli-turnier._tcp</string>
        <string>_tavli-turnier._udp</string>
    </array>
</dict>
</plist>
